cat > .gitignore << 'EOF'
# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/

# Virtual Environment
.venv/
venv/
env/

# Django
*.log
local_settings.py
db.sqlite3
media/

# MySQL
*.sql
*.dump

# Environment variables
.env
.env.local

# macOS
.DS_Store
.AppleDouble
.LSOverride

# IDE
.vscode/
.idea/
*.swp
*.swo

# Testing
.coverage
htmlcov/
.pytest_cache/

# Static files collected
staticfiles/
static_root/

# Migrations (optional — remove this if you want to track migrations)
# newsApp/migrations/

EOF